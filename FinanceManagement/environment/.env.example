# ============================================================
# .env.example - Template biến môi trường cho production (VPS)
# ============================================================
# Hướng dẫn:
#   1. Copy file này thành .env trên VPS
#   2. Điền đầy đủ các giá trị
#   3. Chạy: docker compose -f docker-compose.prod.yml --env-file .env up -d
#
# QUAN TRỌNG: File .env thật KHÔNG được commit lên git!
# ============================================================


# ============================================================
# Domain & SSL (Let's Encrypt)
# ============================================================

# Domain chính của ứng dụng (không có https://)
# Ví dụ: financeapp.vn
DOMAIN=your-domain.com

# Email để Let's Encrypt gửi thông báo hết hạn cert
ACME_EMAIL=your@email.com


# ============================================================
# VPS
# ============================================================

# IP public của VPS (dùng cho Kafka external listener)
# Lấy bằng lệnh: curl ifconfig.me
VPS_IP=your.vps.public.ip


# ============================================================
# Docker Registry (tuỳ chọn)
# ============================================================

# Nếu push images lên Docker Hub: yourname/
# Nếu build trực tiếp trên VPS: để trống
DOCKER_REGISTRY=


# ============================================================
# Database - MySQL
# ============================================================

# Mật khẩu root MySQL (dùng chung cho user, finance, key databases)
# Đặt mật khẩu mạnh, không dùng "root"
MYSQL_ROOT_PASSWORD=change_me_strong_password


# ============================================================
# Database - MongoDB
# ============================================================

# Mật khẩu root MongoDB
MONGO_ROOT_PASSWORD=change_me_strong_password


# ============================================================
# Database - PostgreSQL (AI Service)
# ============================================================

POSTGRES_PASSWORD=change_me_strong_password


# ============================================================
# MinIO - Object Storage
# ============================================================

# Access key (username) - mặc định dev là "loki"
MINIO_ACCESS_KEY=your_minio_access_key

# Secret key (password) - mặc định dev là "supersecret"
MINIO_SECRET_KEY=change_me_strong_password


# ============================================================
# Keycloak - Authentication
# ============================================================

# Mật khẩu admin Keycloak console
# Truy cập: https://auth.${DOMAIN}
KEYCLOAK_ADMIN_PASSWORD=change_me_strong_password


# ============================================================
# Google Gemini AI
# ============================================================

# API Key từ Google AI Studio: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here


# ============================================================
# Google Cloud KMS (KeyManagementService)
# ============================================================

# Đường dẫn tới file service account JSON trên VPS
# Ví dụ: /home/ubuntu/secrets/gcp-credentials.json
# Lưu ý: Copy file này lên VPS trước khi chạy docker compose
GCP_CREDENTIALS_PATH=/home/ubuntu/secrets/gcp-credentials.json
